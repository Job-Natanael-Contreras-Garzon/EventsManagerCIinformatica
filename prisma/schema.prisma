generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Enum: Role
// Roles de usuario del sistema
// ─────────────────────────────────────────────
enum Role {
  ADMIN
  COORDINATOR
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  events    Event[]

  @@map("categories")
}

model Event {
  id                   String         @id @default(uuid())
  name                 String
  description          String?
  /// Tipo: INDIVIDUAL, TEAM, OPEN (informativo, sin inscripciones)
  type                 String         @default("INDIVIDUAL")
  /// Estado del evento: AVAILABLE (próximo), IN_PROGRESS (en curso), FINISHED (finalizado)
  status               String         @default("AVAILABLE")
  /// Género al que va dirigido: WOMEN, MEN, BOTH
  gender               String         @default("BOTH")
  date                 DateTime
  /// Controla si las inscripciones están abiertas o cerradas (independiente del status)
  isActive             Boolean        @default(true)
  registrationDeadline DateTime?
  maxParticipants      Int?
  maxTeamMembers       Int            @default(5)
  imageBase64          String?
  categoryId           String
  /// Nombre del ganador o equipo ganador (opcional, no aplica a conferencias/OPEN)
  winnerName           String?
  /// ID del participante ganador (opcional)
  winnerParticipantId  String?
  /// ID del equipo ganador (opcional)
  winnerTeamId         String?
  /// Campos dinámicos adicionales en formato JSON: [{ label, value }]
  customFields         Json           @default("[]")
  /// Campos desactivados del catálogo público (array de nombres de campo)
  disabledFields       String[]       @default([])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  encargados           Encargado[]
  category             Category       @relation(fields: [categoryId], references: [id])
  registrations        Registration[]
  teams                Team[]

  @@map("events")
}

model Encargado {
  id          String   @id @default(uuid())
  name        String
  /// Número de celular en formato internacional (ej: 573001234567)
  phone       String
  /// Link directo para abrir WhatsApp: https://wa.me/{phone}
  whatsappUrl String
  eventId     String
  /// Referencia opcional al usuario del sistema (admin o coordinador)
  userId      String?
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("encargados")
}

model Participant {
  id            String         @id @default(uuid())
  fullName      String
  /// Correo electrónico — único cuando está presente, nullable
  email         String?        @unique
  /// Código universitario de identificación (ej: 20231234)
  registerCode  String         @unique
  /// Número de celular del participante (requerido)
  phone         String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]
  leaderOf      Team[]         @relation("TeamLeader")

  @@map("participants")
}

model Registration {
  id               String             @id @default(uuid())
  confirmationCode String             @unique
  status           RegistrationStatus @default(PENDING)
  participantId    String
  eventId          String
  /// Indica si fue un registro manual por admin/coordinador
  isManual         Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  event            Event              @relation(fields: [eventId], references: [id])
  participant      Participant        @relation(fields: [participantId], references: [id])

  // Equipo al que pertenece la inscripción (opcional)
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  @@unique([participantId, eventId])
  @@map("registrations")
}

// ─────────────────────────────────────────────
// Model: Team
// Grupo/equipo registrado para un evento.
// ─────────────────────────────────────────────
model Team {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique // Código único de 6 caracteres (ej: "A8B2C4")
  
  // Evento al que pertenece el equipo (FK)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  
  // Participante líder (FK)
  leaderId  String
  leader    Participant @relation("TeamLeader", fields: [leaderId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Inscripciones de los miembros del equipo
  registrations Registration[]

  @@map("teams")
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id        String     @id @default(uuid())
  name      String
  username  String     @unique
  password  String
  /// Rol del usuario en el sistema
  role      Role       @default(ADMIN)
  /// Número de celular (obligatorio — admins también pueden ser encargados)
  phone     String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  encargados Encargado[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Model: SystemConfig
// Configuración dinámica del portal (editable desde el dashboard admin)
// ─────────────────────────────────────────────
model SystemConfig {
  id          String   @id @default("default")
  /// Título de la sección principal (ej: "SEMANA FACULTATIVA 2026")
  title1      String   @default("SEMANA FACULTATIVA 2026")
  /// Título secundario / heading principal (ej: "Catálogo de Eventos")
  title2      String   @default("Catálogo de Eventos")
  /// Descripción del portal
  description String   @default("Portal Oficial de Inscripcion para Actividades organizadas por el Centro Interno de Ingenieria Informatica. Encuentra todos los Eventos Disponibles, Inscribete facilmente y se parte de nuestras Actividades academicas, deportivas y culturales.")
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}
